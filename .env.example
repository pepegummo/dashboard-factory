# Copy to .env at the repo root — docker compose reads it automatically.
# Used by docker-compose.yml variable substitution.

# Backend (chat). Required for the Explore chat to work.
GROQ_API_KEY=
# Optional: override the default Qwen model
# GROQ_MODEL=qwen/qwen3-32b
# Optional: override the system prompt (multiline not supported via env)
# CHAT_SYSTEM_PROMPT=
# Optional: model temperature 0.0–1.0 (default 0.4)
# CHAT_TEMPERATURE=0.4

# Frontend needs no env vars: it's a static nginx build that proxies /api to
# the backend, so the API key never reaches the browser.
